{
  "name": "@hacksis/zebra-browser-print-wrapper",
  "version": "1.0.0",
  "description": "Zebra Browser Print Javascript Wrapper",
  "author": "BaptisteDrm",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "yarn build",
    "lint": "tslint -p tsconfig.json"
  },
  "keywords": [
    "zpl",
    "zebra",
    "zebra programming language",
    "zebra printers",
    "barcode"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^24.11.0",
    "tslint": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.13.0"
}